NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — never exposed to the browser. Milo tries these in order:
# Gemini (primary, free tier, handles images) -> Groq (fallback, free, text-only)
# -> OpenRouter (third layer, free, text-only) -> Anthropic (optional last resort / future paid tier).
# You only need Gemini + Groq to run Milo for free; OpenRouter is optional extra redundancy.

# Gemini: get a free key at https://aistudio.google.com (no card required)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Groq: get a free key at https://console.groq.com (no card required)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: get a free key at https://openrouter.ai/keys (no card required for free models)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional — only needed if you want Anthropic as a further fallback / paid tier
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-5

# Powers the admin/creator-only AI tools (application review, video
# metadata suggestions, tutor-response drafting help) via /api/admin-ai —
# kept separate from Milo's student-facing provider chain above. Still
# worth a real read of NVIDIA's terms before this sees production traffic:
# their free tier is scoped to development/testing/evaluation, and routing
# it to admin-only tools narrows that exposure but doesn't resolve it.
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nvidia-nemotron-nano-9b-v2

# Optional: "mock" for canned offline responses during local UI work
NEXT_PUBLIC_AI_PROVIDER=

# --- Not Next.js env vars — these are Supabase project secrets/settings ---
# Required for real email notifications (see
# supabase/functions/send-notification-email/index.ts for full setup steps):
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxx
#   supabase secrets set NOTIFICATION_FROM_EMAIL="Cognify <notifications@yourdomain.com>"
#   supabase secrets set APP_URL=https://your-deployed-app-url.com
# Plus, once, from the Supabase SQL editor:
#   alter database postgres set app.settings.supabase_url = 'https://<project-ref>.supabase.co';
#   alter database postgres set app.settings.service_role_key = '<service-role-key>';
