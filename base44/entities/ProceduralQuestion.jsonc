{
  "name": "ProceduralQuestion",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "description": "The question prompt"
    },
    "passage": {
      "type": "string",
      "description": "Optional reading passage or context"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Multiple choice options (exactly 4)"
    },
    "correct_index": {
      "type": "number",
      "description": "Index of the correct option (0-3)"
    },
    "explanation": {
      "type": "string"
    },
    "subject": {
      "type": "string",
      "enum": [
        "Math",
        "Reading",
        "Writing"
      ],
      "default": "Math"
    },
    "topic": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "Easy",
        "Medium",
        "Hard"
      ],
      "default": "Medium"
    },
    "question_type": {
      "type": "string",
      "default": "Multiple Choice"
    },
    "provider": {
      "type": "string",
      "description": "Which AI provider generated this (gemini, groq, openrouter)"
    },
    "times_served": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "prompt"
  ]
}